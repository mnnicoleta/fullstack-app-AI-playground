{
    "name": "onlineshopui",
    "version": "0.0.0",
    "scripts": {
        "ng": "ng",
        "start": "ng serve",
        "start:wsl": "ng serve --host 0.0.0.0 --configuration wsl",
        "start:mock": "ng serve --configuration mock",
        "build": "ng build",
        "watch": "ng build --watch --configuration development",
        "test": "ng test",
        "test:ci": "ng test --no-watch --code-coverage --browsers=ChromeHeadlessCI",
        "test:coverage": "ng test --no-watch --code-coverage",
        "test:watch": "ng test",
        "lint": "ng lint",
        "format": "prettier --write \"src/**/*.{ts,html,css,scss}\""
    },
    "private": true,
    "packageManager": "npm@11.6.1",
    "dependencies": {
        "@angular/cdk": "^21.2.2",
        "@angular/common": "^21.2.0",
        "@angular/compiler": "^21.2.0",
        "@angular/core": "^21.2.0",
        "@angular/forms": "^21.2.0",
        "@angular/platform-browser": "^21.2.0",
        "@angular/router": "^21.2.0",
        "lucide-angular": "^0.577.0",
        "rxjs": "~7.8.0",
        "tslib": "^2.3.0",
        "zone.js": "~0.15.0"
    },
    "devDependencies": {
        "@angular-devkit/build-angular": "^21.2.16",
        "@angular/build": "^21.2.2",
        "@angular/cli": "^21.2.2",
        "@angular/compiler-cli": "^21.2.0",
        "@angular/platform-browser-dynamic": "^21.2.0",
        "@eslint/js": "^10.0.1",
        "@tailwindcss/postcss": "^4.1.12",
        "@types/jasmine": "^6.0.0",
        "angular-eslint": "21.3.0",
        "eslint": "^10.0.2",
        "jasmine-core": "^6.3.0",
        "karma": "^6.4.4",
        "karma-chrome-launcher": "^3.2.0",
        "karma-coverage": "^2.2.1",
        "karma-jasmine": "^5.1.0",
        "karma-jasmine-html-reporter": "^2.2.0",
        "playwright": "^1.61.0",
        "postcss": "^8.5.3",
        "prettier": "3.8.1",
        "tailwindcss": "^4.1.12",
        "typescript": "~5.9.2",
        "typescript-eslint": "8.56.1"
    },
    "engines": {
        "node": ">=22.0.0"
    },
    "optionalDependencies": {
        "@rollup/rollup-linux-x64-gnu": "^4.62.2"
    }
}
